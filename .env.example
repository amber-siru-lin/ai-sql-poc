# Copy to .env for optional overrides (file is gitignored)

# AWS — use your org's SSO profile name from ~/.aws/config
# AWS_PROFILE=your-sso-profile-name
# AWS_REGION=us-east-1

# Bedrock model (must be enabled in your AWS account/region)
# BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
# BEDROCK_MODEL_LABEL=Nova Pro

# UI branding (optional)
# APP_TITLE=AI SQL Assistant
# DATASET_LABEL=Analytics

# Snowflake overrides (optional if set in config/snowflake_config.py)
# SNOWFLAKE_DATABASE=YOUR_DATABASE
# SNOWFLAKE_SCHEMA=YOUR_SCHEMA
# SCHEMA_MARKDOWN_PATH=schema/your_schema.md
# WREN_PROFILE_NAME=default
# WREN_STRICT_TPCH_GUARD=false

# Query audit log (S3-only when bucket is set; default destination=s3)
# AUDIT_S3_BUCKET=your-org-ai-sql-audit-dev
# AUDIT_S3_PREFIX=audit/
# AUDIT_DESTINATION=s3

# Phase 3.6 — LangGraph Postgres checkpointer (optional)
# Start DB: docker compose up -d
# POSTGRES_USER=ai_sql
# POSTGRES_PASSWORD=ai_sql_dev
# POSTGRES_DB=ai_sql_poc
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://ai_sql:ai_sql_dev@localhost:5432/ai_sql_poc

# Optional LangSmith tracing (Phase 2F)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=ai-sql-deep-agent-poc

# Semantic layer editor — GitHub PR workflow (Unit 4; server-side only)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=owner/repo
# GITHUB_DEFAULT_BRANCH=main
