# Copy to .env for optional overrides (file is gitignored)
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Query audit log (S3-only when bucket is set; default destination=s3)
# AUDIT_S3_BUCKET=cta-poc-ai-sql-audit-dev-654654461736
# AUDIT_S3_PREFIX=audit/
# AUDIT_DESTINATION=s3

# Phase 3.6 — LangGraph Postgres checkpointer (optional)
# Start DB: docker compose up -d
# POSTGRES_USER=ai_sql
# POSTGRES_PASSWORD=ai_sql_dev
# POSTGRES_DB=ai_sql_poc
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://ai_sql:ai_sql_dev@localhost:5432/ai_sql_poc

# Optional LangSmith tracing (Phase 2F)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=ai-sql-deep-agent-poc
