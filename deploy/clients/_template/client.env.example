# Copy to clients/<name>/client.env — do not commit filled secrets.

AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
AWS_PROFILE=

# Amplify (after first pipeline or console setup)
AMPLIFY_APP_ID=
HOSTING_BRANCH=main

# Frontend build-time (Vite)
VITE_API_URL=
VITE_COPILOT_RUNTIME_URL=

# Lambda / API runtime (Amplify secret() or SSM — not plaintext in defineFunction)
DATABASE_URL=
AUDIT_S3_BUCKET=
AUDIT_S3_PREFIX=audit/
AUDIT_DESTINATION=s3
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
SNOWFLAKE_SECRET_NAME=ai-sql-poc/snowflake

# Feature flags per client
WREN_ENABLED=false
CORS_ORIGINS=
